            {
              "id": "choice_001_b",
              "text": "我还有事",
              "gotoSceneId": "scene_rooftop_breeze",
              "effects": [
                {
                  "type": "variable_set",
                  "variableId": "flag_walk_home",
                  "value": false
                },
                {
                  "type": "variable_set",
                  "variableId": "player_route",
                  "value": "rooftop"
                }
              ]
            }

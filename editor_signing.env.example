# Tony Na Engine 商业签名 / 公证环境变量示例
# 把这份文件复制成你自己的本地版本后，再填真实证书信息。
# 不要把真实证书密码或 .pfx 文件路径提交进版本库。

# macOS App 签名身份（例：Developer ID Application: Tony Na Studio (TEAMID)）
TONY_NA_EDITOR_MAC_APP_IDENTITY=

# macOS Installer 签名身份（例：Developer ID Installer: Tony Na Studio (TEAMID)）
TONY_NA_EDITOR_MAC_INSTALLER_IDENTITY=

# macOS 公证 profile（先用 xcrun notarytool store-credentials 建好）
TONY_NA_EDITOR_MAC_NOTARY_PROFILE=

# Windows Inno Setup 编译器路径（例：C:\Program Files (x86)\Inno Setup 6\ISCC.exe）
TONY_NA_EDITOR_WINDOWS_ISCC=

# 非 Windows 机器跨环境调用 ISCC 时可选（例：wine64）
TONY_NA_EDITOR_WINDOWS_ISCC_RUNNER=

# Windows signtool 路径（例：C:\Program Files (x86)\Windows Kits\10\App Certification Kit\signtool.exe）
TONY_NA_EDITOR_WINDOWS_SIGNTOOL=

# 非 Windows 机器跨环境调用 signtool 时可选（例：wine64）
TONY_NA_EDITOR_WINDOWS_SIGNTOOL_RUNNER=

# Windows 证书主题名（三选一）
TONY_NA_EDITOR_WINDOWS_CERT_SUBJECT=

# Windows 证书指纹（三选一）
TONY_NA_EDITOR_WINDOWS_CERT_THUMBPRINT=

# Windows PFX 文件路径（三选一）
TONY_NA_EDITOR_WINDOWS_PFX_PATH=

# Windows PFX 密码（如果用了 PFX 再填）
TONY_NA_EDITOR_WINDOWS_PFX_PASSWORD=

# Windows 时间戳地址（可选，默认会使用 DigiCert）
TONY_NA_EDITOR_WINDOWS_TIMESTAMP_URL=http://timestamp.digicert.com
